NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
MEDIA_TOKEN_SECRET=replace-with-a-long-random-secret
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional, only for future OpenRouter transcript jobs:
# OPENROUTER_TRANSCRIPT_MODEL=google/gemini-2.5-flash
EDUFLEET_OFFLINE_ALLOW_DEBUG_ATTESTATION=false
EDUFLEET_OFFLINE_EXPECTED_PACKAGE_NAME=com.edufleet.offline
EDUFLEET_OFFLINE_PLAY_INTEGRITY_MAX_AGE_SECONDS=300
# Provide one of the following for server-side Play Integrity decode:
EDUFLEET_PLAY_INTEGRITY_SERVICE_ACCOUNT_PATH=/absolute/path/to/play-integrity-service-account.json
# EDUFLEET_PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# EDUFLEET_PLAY_INTEGRITY_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59
